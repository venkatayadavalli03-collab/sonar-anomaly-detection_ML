import  piplite
await  piplite.install(['seaborn', 'openpyxl'])
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.ensemble import IsolationForest
from sklearn.decomposition import PCA

# 1. Loading the file 
file_name = "sonar.xlsx" 
df = None
df = pd.read_excel("sonar.xlsx")
print(f"Successfully loaded")

# 2. Separate Features (first 60 columns) and Ground Truth (last column)
X = df.iloc[:, :60]
y = df.iloc[:, 60]

# 3. Train the Isolation Forest
# We tell the model to flag the 10% most 'unusual' points
iso_forest = IsolationForest(contamination=0.1, n_estimators=200, random_state=42)
df['anomaly_flag'] = iso_forest.fit_predict(X)

# 4. PCA: Compress 60 frequencies into 2D so we can see them on a graph
pca = PCA(n_components=2)
pca_result = pca.fit_transform(X)
df['pca_1'] = pca_result[:, 0]
df['pca_2'] = pca_result[:, 1]

# 5. Visualize the "Isolation" logic
plt.figure(figsize=(10, 6))
sns.scatterplot(
    data=df, x='pca_1', y='pca_2', 
    hue='anomaly_flag', palette={1: 'dodgerblue', -1: 'crimson'},
    alpha=0.8, s=60
)
plt.title("Sonar Anomaly Detection: Isolation Forest Results")
plt.legend(title="Model Verdict", labels=['Normal (1)', 'Anomaly (-1)'])
plt.grid(True, linestyle='--', alpha=0.5)
plt.show()

# 6. The "Truth Check"
# This compares the unsupervised anomalies against your M/R labels
print("\n--- Comparison: How many Mines/Rocks were flagged as 'Anomalous'? ---")
comparison = pd.crosstab(y, df['anomaly_flag'], rownames=['Actual Ground Truth'], colnames=['Is it an Anomaly?'])
comparison.columns = ['Yes (Flagged)', 'No (Normal)']
print(comparison)
# 7. Comparison Table
print("\n--- Ground Truth vs Anomaly Detection ---")
print(pd.crosstab(y, df['anomaly_flag'], rownames=['Actual'], colnames=['Is Anomaly?']))
